---
import Base from '../layouts/Base.astro';
---

<Base title="My Trip">
  <div class="max-w-2xl mx-auto p-4">
    <div class="flex justify-between items-center mb-4 print:hidden">
      <a href="/" class="btn btn-ghost btn-sm">&larr; Back to map</a>
    </div>

    <h1 class="text-xl font-bold mb-2">My Trip</h1>

    <div id="empty-state" class="hidden text-center py-12 text-base-content/50">
      <p class="text-lg mb-2">No spots in your trip yet</p>
      <p class="text-sm">Go to the <a href="/" class="link">map</a> and click "+ Trip" on a spot popup to add it.</p>
    </div>

    <div id="trip-content" class="hidden">
      <div id="trip-map" class="w-full h-48 rounded-lg mb-4 print:hidden"></div>

      <div class="flex flex-wrap gap-2 mb-4 print:hidden">
        <button id="export-gpx" class="btn btn-sm btn-outline">Export GPX</button>
        <a id="gmaps-link" href="#" target="_blank" class="btn btn-sm btn-outline">Google Maps route</a>
        <button onclick="window.print()" class="btn btn-sm btn-outline">Print checklist</button>
        <button id="clear-trip" class="btn btn-sm btn-ghost text-error">Clear trip</button>
      </div>

      <div id="trip-list" class="space-y-3"></div>
    </div>
  </div>
</Base>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<style>
  @media print {
    nav, footer, #trip-map, .print\\:hidden { display: none !important; }
    body { overflow: visible !important; height: auto !important; }
    .trip-card { break-inside: avoid; border: 1px solid #ccc !important; }
  }
</style>

<script>
  import { MAP_CENTER_LAT, MAP_CENTER_LNG } from 'astro:env/client';

  declare const L: any;

  function getTrip(): number[] {
    try { return JSON.parse(localStorage.getItem('cleanup-trip') || '[]'); }
    catch { return []; }
  }

  const tripIds = getTrip();
  const emptyState = document.getElementById('empty-state')!;
  const tripContent = document.getElementById('trip-content')!;

  if (tripIds.length === 0) {
    emptyState.classList.remove('hidden');
  } else {
    tripContent.classList.remove('hidden');
    loadTrip();
  }

  async function loadTrip() {
    // Fetch each spot's details
    const spots: any[] = [];
    for (const id of tripIds) {
      const res = await fetch(`/api/spots/${id}`);
      if (res.ok) {
        spots.push(await res.json());
      }
    }

    if (spots.length === 0) {
      tripContent.classList.add('hidden');
      emptyState.classList.remove('hidden');
      return;
    }

    // Render map with pins
    const map = L.map('trip-map').setView([MAP_CENTER_LAT, MAP_CENTER_LNG], 13);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '&copy; OpenStreetMap', maxZoom: 19,
    }).addTo(map);

    const bounds: any[] = [];
    for (const spot of spots) {
      L.marker([spot.latitude, spot.longitude]).addTo(map)
        .bindPopup(spot.title);
      bounds.push([spot.latitude, spot.longitude]);
    }
    if (bounds.length > 1) {
      map.fitBounds(bounds, { padding: [30, 30] });
    } else if (bounds.length === 1) {
      map.setView(bounds[0], 15);
    }

    // Render spot list
    const listEl = document.getElementById('trip-list')!;
    for (const spot of spots) {
      const openTasks = spot.tasks.filter((t: any) => t.status !== 'done');
      const taskLines = openTasks.map((t: any) => {
        const type = t.cleanup_type.replace(/_/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase());
        return `<li class="flex items-start gap-2">
          <input type="checkbox" class="checkbox checkbox-xs mt-1 print:border print:border-gray-400" />
          <span><span class="text-xs text-base-content/50">${type}</span>${t.description ? ' — ' + t.description : ''}</span>
        </li>`;
      }).join('');

      listEl.innerHTML += `
        <div class="trip-card bg-base-100 border border-base-300 rounded-lg p-3">
          <div class="flex justify-between items-start">
            <div>
              <h3 class="font-semibold">${spot.title}</h3>
              <p class="text-xs text-base-content/50">${spot.location_type.replace(/_/g, ' ')} &middot; ${spot.latitude.toFixed(4)}, ${spot.longitude.toFixed(4)}</p>
            </div>
            <a href="/spot/${spot.id}" class="text-xs link print:hidden">Details</a>
          </div>
          ${openTasks.length > 0 ? `<ul class="mt-2 space-y-1 text-sm">${taskLines}</ul>` : '<p class="text-sm text-success mt-1">All tasks done</p>'}
        </div>
      `;
    }

    // Google Maps multi-stop link
    const gmapsLink = document.getElementById('gmaps-link') as HTMLAnchorElement;
    const waypoints = spots.map((s: any) => `${s.latitude},${s.longitude}`).join('/');
    gmapsLink.href = `https://www.google.com/maps/dir/${waypoints}`;

    // GPX export
    const gpxBtn = document.getElementById('export-gpx')!;
    gpxBtn.addEventListener('click', () => {
      const wpts = spots.map((s: any) =>
        `  <wpt lat="${s.latitude}" lon="${s.longitude}"><name>${s.title.replace(/&/g, '&amp;').replace(/</g, '&lt;')}</name></wpt>`
      ).join('\n');

      const gpx = `<?xml version="1.0" encoding="UTF-8"?>
<gpx version="1.1" creator="local-cleanup" xmlns="http://www.topografix.com/GPX/1/1">
${wpts}
</gpx>`;

      const blob = new Blob([gpx], { type: 'application/gpx+xml' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = 'cleanup-trip.gpx';
      a.click();
      URL.revokeObjectURL(url);
    });

    // Clear trip
    const clearBtn = document.getElementById('clear-trip')!;
    clearBtn.addEventListener('click', () => {
      localStorage.removeItem('cleanup-trip');
      window.location.reload();
    });
  }
</script>
